{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "quickencode",
  "version": "0.1.0",
  "identifier": "com.itzsfox.quickencode",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "quickencode",
        "width": 860,
        "height": 700,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [],
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ]
  }
}