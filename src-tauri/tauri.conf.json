{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "quickencode",
  "version": "0.1.0",
  "identifier": "com.itzsfox.quickencode",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "quick encode.",
        "width": 900,
        "height": 680,
        "minWidth": 720,
        "minHeight": 540,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/qe-logo.svg"
    ],
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ]
  }
}
