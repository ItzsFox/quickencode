{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "quick encode",
  "mainBinaryName": "quick encode",
  "version": "2.1.1",
  "identifier": "com.itzsfox.quickencode",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "quick encode.",
        "width": 900,
        "height": 680,
        "minWidth": 720,
        "minHeight": 540,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/ffmpeg",
      "binaries/ffprobe"
    ],
    "windows": {
      "wix": {
        "fragmentPaths": ["wix/context-menu.wxs"],
        "componentRefs": ["MP4ContextMenuComp"]
      }
    }
  }
}
